local function getMurderer()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LP then
			local char = p.Character
			local backpack = p:FindFirstChild("Backpack")
			if (char and char:FindFirstChild("Knife")) or (backpack and backpack:FindFirstChild("Knife")) then
				return p
			end
		end
	end
	for name, data in pairs(roleCache) do
		if data.Role == "Murderer" then
			local p = Players:FindFirstChild(name)
			if p then return p end
		end
	end
	return nil
end

local function fireGun()
	local target = getMurderer()
	if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
		local targetHRP = target.Character.HumanoidRootPart
		local gun = LP.Character:FindFirstChild("Gun") or (LP.Backpack and LP.Backpack:FindFirstChild("Gun"))
		
		if gun and gun:FindFirstChild("Shoot") then
			local velocity = targetHRP.Velocity
			local predictedPos = targetHRP.Position + (velocity * 0.12)
			local cf = CFrame.new(targetHRP.Position, predictedPos)

			gun.Shoot:FireServer(cf, CFrame.new(predictedPos))
		end
	end
end

