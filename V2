local function IsAlive(playerData)
	return playerData and not playerData.Killed and not playerData.Dead
end

local function GetRoleColor(playerName, playerData)
	if not playerData or playerData.Role == "" or playerData.Role == nil then
		return "Default"
	end

	if playerName == Murder and IsAlive(playerData) then
		if GetMurdererESP() then return Color3.fromRGB(225, 0, 0) end
	elseif playerName == Sheriff and IsAlive(playerData) then
		if GetSheriffESP() then return Color3.fromRGB(0, 0, 225) end
	elseif (playerName == Hero or playerData.Role == "Hero" or playerData.HasGun) and IsAlive(playerData) then
		if GetHeroESP() then return Color3.fromRGB(255, 250, 0) end
	elseif IsAlive(playerData) then
		if GetInnocentESP() then return Color3.fromRGB(0, 225, 0) end
	end
	return nil
end

local function UpdateHighlights()
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LP then
			local character = player.Character
			if character then
				local highlight = character:FindFirstChild("ExodusHighlight")
				if not highlight then
					highlight = Instance.new("Highlight")
					highlight.Name = "ExodusHighlight"
					highlight.Parent = character
				end
				
				local playerData = roles[player.Name]
				local res = GetRoleColor(player.Name, playerData)
				
				if res == "Default" then
					highlight.Enabled = true
					highlight.FillTransparency = 1
					highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
					highlight.OutlineTransparency = 0
				elseif typeof(res) == "Color3" then
					highlight.Enabled = true
					highlight.FillColor = res
					highlight.FillTransparency = 0.5
					highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
					highlight.OutlineTransparency = 0
				else
					highlight.Enabled = false
				end
			end
		end
	end
end

local function UpdateRoles()
	local success, result = pcall(function()
		return ReplicatedStorage:FindFirstChild("GetPlayerData", true):InvokeServer()
	end)
	
	if success and result then
		roles = result
		Murder, Sheriff, Hero = nil, nil, nil
		for name, data in pairs(roles) do
			if data.Role == "Murderer" then
				Murder = name
			elseif data.Role == "Sheriff" then
				Sheriff = name
			elseif data.Role == "Hero" or data.HasGun then
				Hero = name
			end
		end
	else
		roles = {}
	end
end

